{
  "name": "moment-insight-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test api/*.test.mjs src/server/**/*.test.mjs && npm --prefix tools/naver-place-rank-collector test",
    "check:quality": "npm run check:baseline && npm run check:server && npm run check:rank-cron && npm run check:rank-matching && npm run check:keyword-trend && npm test && npm run build:vercel",
    "build:vercel": "npm run check:server && find api -name '*.mjs' -print0 | xargs -0 -n1 node --check && node scripts/build-vercel-static.mjs",
    "clean:workspace": "node scripts/clean-workspace.mjs",
    "clean:workspace:deps": "node scripts/clean-workspace.mjs --deps",
    "clean:workspace:dry": "node scripts/clean-workspace.mjs --dry-run",
    "work:autosave": "node scripts/work-spec-autosave.mjs",
    "check:baseline": "node scripts/check-release-baseline.mjs",
    "check:env": "node scripts/check-runtime-env.mjs",
    "check:env:naver": "node scripts/check-runtime-env.mjs --naver",
    "check:keyword-trend": "node scripts/check-keyword-trend-scaling.mjs",
    "check:rank-cron": "node scripts/check-rank-cron-schedule.mjs",
    "check:rank-matching": "node scripts/check-naver-rank-matching.mjs",
    "check:supabase": "node 06_Supabase_연동/check-supabase.mjs",
    "check:admin-api": "node 06_Supabase_연동/check-admin-api.mjs",
    "check:edge-api": "node 06_Supabase_연동/check-edge-api.mjs",
    "check:server": "find src/server -name '*.mjs' -print0 | xargs -0 -n1 node --check",
    "dev:server": "node src/server/local-dev.mjs",
    "deploy:backend": "node 06_Supabase_연동/deploy-backend.mjs",
    "seed:demo": "node 06_Supabase_연동/seed-demo-via-api.mjs",
    "supabase:db:push": "npx supabase db push",
    "supabase:functions:deploy": "npx supabase functions deploy moment-api"
  },
  "dependencies": {
    "@supabase/server": "^1.1.0",
    "@supabase/supabase-js": "^2.108.2",
    "pptxgenjs": "^4.0.1"
  }
}
