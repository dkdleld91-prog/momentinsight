PORT=8790

# NAVER Search Ad API: absolute monthly search volume, CTR, competition
NAVER_SEARCHAD_API_KEY=your-searchad-api-key
NAVER_SEARCHAD_SECRET_KEY=your-searchad-secret-key
NAVER_SEARCHAD_CUSTOMER_ID=your-searchad-customer-id

# NAVER API Hub: migrated Search, Search Trend, Shopping Insight
# Keep Production on legacy until Hub keys and sample responses are verified in Preview.
NAVER_API_HUB_MODE=legacy
NAVER_API_HUB_CLIENT_ID=your-naver-api-hub-client-id
NAVER_API_HUB_CLIENT_SECRET=your-naver-api-hub-client-secret

# Legacy NAVER Developers DataLab fallback during the migration window
NAVER_DATALAB_CLIENT_ID=your-datalab-client-id
NAVER_DATALAB_CLIENT_SECRET=your-datalab-client-secret

# Legacy NAVER Developers Shopping Search: ends 2026-07-31 with no official replacement
# If the same Naver developer app enables both APIs, copy the same value here explicitly.
NAVER_OPENAPI_CLIENT_ID=your-openapi-client-id
NAVER_OPENAPI_CLIENT_SECRET=your-openapi-client-secret

# Optional. Naver Place rank needs an external collector because official OpenAPI
# does not return a reliable place URL/placeId rank match.
NAVER_PLACE_RANK_API_URL=https://your-collector.example.com/rank/naver-place
NAVER_PLACE_RANK_API_KEY=your-shared-place-rank-collector-secret
NAVER_PLACE_RANK_TIMEOUT_MS=90000

# Optional. Use comma-separated allowed origins in production.
# Example: https://momentinsight.kr,https://www.momentinsight.kr
MI_ALLOWED_ORIGINS=https://insight.momentlabs.co.kr

# Production keyword lookup requires this to be true.
MI_KEYWORD_API_ENABLED=true

# Optional local/prod preflight. When true, check:env fails if Naver keys are missing.
MI_REQUIRE_NAVER_ENV=true
